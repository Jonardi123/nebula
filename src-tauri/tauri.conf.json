{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nebula",
  "version": "0.1.0",
  "identifier": "local.nebula.app",
  "build": {
    "beforeDevCommand": "npm.cmd run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nebula",
        "width": 1440,
        "height": 920,
        "minWidth": 1120,
        "minHeight": 740
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
